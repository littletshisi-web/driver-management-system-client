DB_HOST=localhost# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# Base URL of the backend REST API
VITE_API_BASE_URL=http://localhost:5001/api

# Set to "true" to use mock data instead of live API calls (useful during early dev)
VITE_USE_MOCK=true

# App display name
VITE_APP_NAME=DMS
